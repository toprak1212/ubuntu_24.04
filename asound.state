			dbmax 1200
			dbvalue.0 0
			dbvalue.1 0
		}
	}
	control.20 {
		iface MIXER
		name 'Aux Capture Volume'
		value.0 0
		value.1 0
		comment {
			access 'read write'
			type INTEGER
			count 2
			range '-24 - 24'
			dbmin -1200
			dbmax 1200
			dbvalue.0 0
			dbvalue.1 0
		}
	}
	control.21 {
		iface MIXER
		name 'Capture Source'
		value Mic
		comment {
			access 'read write'
			type ENUMERATED
			count 1
			item.0 Mic
			item.1 'Front Mic'
			item.2 Line
			item.3 Aux
		}
	}
	control.22 {
		iface MIXER
		name 'ADC High-pass Filter Capture Enum'
		value Active
		comment {
			access 'read write'
			type ENUMERATED
			count 1
			item.0 Active
			item.1 Frozen
		}
	}
}
