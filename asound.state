	}
	control.10 {
		iface MIXER
		name 'Analog Input Monitor Playback Switch'
		value false
		comment {
			access 'read write'
			type BOOLEAN
			count 1
		}
	}
	control.11 {
		iface MIXER
		name 'Analog Input Monitor Playback Volume'
		value 1
